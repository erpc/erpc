{
  "uid": "dynamic-block-time",
  "title": "Dynamic Block Time",
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "network",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(erpc_network_dynamic_block_time_milliseconds, network)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Block Time (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "erpc_network_dynamic_block_time_milliseconds{network=~\"$network\"} / 1000",
          "legendFormat": "{{network}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 2,
      "title": "Poll Rate (polls/sec per upstream)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(erpc_upstream_latest_block_polled_total{network=~\"$network\"}[1m])",
          "legendFormat": "{{network}} / {{upstream}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 3,
      "title": "Block Time vs Actual Poll Interval (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "erpc_network_dynamic_block_time_milliseconds{network=~\"$network\"} / 1000",
          "legendFormat": "Block Time: {{network}}"
        },
        {
          "expr": "1 / rate(erpc_upstream_latest_block_polled_total{network=~\"$network\"}[1m])",
          "legendFormat": "Actual: {{network}} / {{upstream}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ],
  "schemaVersion": 39
}
