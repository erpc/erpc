{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "x402 Payment Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Payment Outcomes (rate/min)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(erpc_x402_payment_total{facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator, outcome) * 60",
          "legendFormat": "{{facilitator}} — {{outcome}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Facilitator Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(erpc_x402_facilitator_request_total{facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator, operation, status)",
          "legendFormat": "{{facilitator}} {{operation}} [{{status}}]"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "title": "Facilitator Latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Verify Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"verify\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"verify\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"verify\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 6,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Settle Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"settle\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"settle\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{operation=\"settle\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator))",
          "legendFormat": "{{facilitator}} p99"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 7,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Verify vs Settle Latency Comparison (p95)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(erpc_x402_facilitator_request_duration_seconds_bucket{facilitator=~\"$facilitator\"}[$__rate_interval])) by (le, facilitator, operation))",
          "legendFormat": "{{facilitator}} {{operation}} p95"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 8,
      "title": "Error Rates",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 9,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Facilitator Error Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(erpc_x402_facilitator_request_total{status=\"error\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator, operation) / sum(rate(erpc_x402_facilitator_request_total{facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator, operation)",
          "legendFormat": "{{facilitator}} {{operation}} error %"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "stacking": { "mode": "none" } },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Payment Success Rate (%)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(erpc_x402_payment_total{outcome=\"settled\", facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator) / sum(rate(erpc_x402_payment_total{facilitator=~\"$facilitator\"}[$__rate_interval])) by (facilitator)",
          "legendFormat": "{{facilitator}} success %"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 11,
      "title": "Totals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 } ] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "id": 12,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Payments (Circle)",
