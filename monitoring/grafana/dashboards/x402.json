      "targets": [
        {
          "expr": "sum(erpc_x402_payment_total{facilitator=\"circle\", outcome=\"settled\"})",
          "legendFormat": "settled"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
