      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 36 },
      "id": 15,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Settled (x402org)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(erpc_x402_payment_total{facilitator=\"x402org\", outcome=\"settled\"})",
